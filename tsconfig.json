{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "allowSyntheticDefaultImports": true,
    "importHelpers": true,
    "strict": true,
    "moduleResolution": "node",
    "lib": ["ES6", "DOM"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
